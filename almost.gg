{
  "$schema": "https://opencode.ai/config.json",
  "allowedDirectories": [
    "/Users/phoenix/builder/brandon-stitch",
    "/Users/phoenix/builder",
    "/Users/phoenix/development"
  ],
  "mcp": {
    "my-stitch-mcp": {
      "type": "remote",
      "url": "https://stitch.googleapis.com/mcp",
      "enabled": true,
      "headers": {
         "X-Goog-Api-Key": "{file:.secrets/stitch-key.md}"
      }
    }
  }
}